# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Instagram Integration (Optional - only if using Instagram features)
NEXT_PUBLIC_INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret

# Application URL (will be set automatically by hosting platform)
# For Vercel: https://your-app.vercel.app
# For local development: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Notes:
# - Never commit .env.local or .env with real values
# - Get Supabase credentials from: https://supabase.com/dashboard/project/_/settings/api
# - Get Instagram credentials from: https://developers.facebook.com/apps
# - NEXT_PUBLIC_* variables are exposed to the browser (don't put secrets here)
# - Variables without NEXT_PUBLIC_ are server-side only
